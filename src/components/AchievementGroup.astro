---
import { ArrowUpRight } from "@lucide/astro";
import type { Achievement, AchievementType } from "../data/profile";

type Props = {
  type: AchievementType;
  items: Achievement[];
};

const { type, items } = Astro.props;
---

<section class="achievement-group" aria-labelledby={`achievement-${type}`}>
  <div class="achievement-group-heading">
    <h2 id={`achievement-${type}`}>{type}</h2>
    <span>{items.length} 项</span>
  </div>
  <div class="achievement-list">
    {
      items.map((item) => (
        <article class="achievement-item">
          <div class="achievement-meta">
            <span>{item.organization}</span>
            <time>{item.date}</time>
          </div>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          {
            item.link && (
              <a href={item.link} target="_blank" rel="noreferrer">
                查看链接
                <ArrowUpRight size={16} aria-hidden="true" />
              </a>
            )
          }
        </article>
      ))
    }
  </div>
</section>
