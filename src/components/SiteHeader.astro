---
import { profile } from "../data/profile";
import { withBase } from "../utils/paths";

const navItems = [
  { label: "首页", href: withBase() },
  { label: "简历", href: withBase("resume/") },
  { label: "项目", href: withBase("projects/") },
  { label: "成果", href: withBase("achievements/") },
];
---

<header class="site-header">
  <a class="brand" href={withBase()} aria-label="返回首页">
    <span class="brand-mark">{profile.name.slice(0, 1)}</span>
    <span class="brand-text">
      <strong>{profile.name}</strong>
      <small>Academic Portfolio</small>
    </span>
  </a>
  <nav class="site-nav" aria-label="主导航">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
