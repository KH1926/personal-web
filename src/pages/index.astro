---
import { ArrowRight, Code, FileText, Mail } from "@lucide/astro";
import ProfilePanel from "../components/ProfilePanel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  achievements,
  highlights,
  profile,
  profileStats,
  projects,
  researchInterests,
  skills,
} from "../data/profile";
import { withBase } from "../utils/paths";

const featuredProjects = projects.slice(0, 2);
const featuredAchievements = achievements.slice(0, 3);
---

<BaseLayout title="首页" description="个人学术简历、研究方向、项目成果与竞赛荣誉展示。">
  <section class="home-hero">
    <div class="hero-copy">
      <span class="eyebrow">Academic Portfolio · GitHub Pages</span>
      <h1>{profile.name}</h1>
      <p class="hero-title">{profile.title}</p>
      <p class="hero-summary">{profile.summary}</p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("resume/")}>
          <FileText size={18} aria-hidden="true" />
          查看简历
        </a>
        <a class="button" href={profile.githubUrl} target="_blank" rel="noreferrer">
          <Code size={18} aria-hidden="true" />
          GitHub
        </a>
        <a class="button" href={`mailto:${profile.email}`}>
          <Mail size={18} aria-hidden="true" />
          联系
        </a>
      </div>
      <dl class="hero-stat-strip">
        {
          profileStats.map((stat) => (
            <div>
              <dt>{stat.value}</dt>
              <dd>{stat.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>
    <ProfilePanel />
  </section>

  <section class="content-section highlight-section">
    <SectionTitle
      eyebrow="Highlights"
      title="展示重点"
      description="把研究兴趣、工程实践和表达能力组织成可扫描的首页入口。"
    />
    <div class="highlight-grid">
      {
        highlights.map((item) => (
          <article>
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-section">
    <SectionTitle
      eyebrow="Focus"
      title="研究与实践方向"
      description="用标签快速呈现当前关注的问题域、方法和工程输出。"
    />
    <div class="interest-grid">
      {researchInterests.map((interest) => <span>{interest}</span>)}
    </div>
  </section>

  <section class="content-section">
    <SectionTitle
      eyebrow="Projects"
      title="代表项目"
      description="用项目周期、承担角色和产出结果补足项目可信度，而不只是罗列技术栈。"
    />
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <a class="text-link" href={withBase("projects/")}>
      查看全部项目
      <ArrowRight size={16} aria-hidden="true" />
    </a>
  </section>

  <section class="content-section two-column index-summary">
    <div>
      <SectionTitle eyebrow="Skills" title="能力结构" />
      <div class="skill-stack">
        {
          skills.map((skill) => (
            <article>
              <h3>{skill.group}</h3>
              <p>{skill.items.join(" / ")}</p>
            </article>
          ))
        }
      </div>
    </div>
    <div>
      <SectionTitle eyebrow="Outputs" title="近期成果" />
      <div class="compact-list">
        {
          featuredAchievements.map((item) => (
            <article>
              <span>{item.type} · {item.date}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </article>
          ))
        }
      </div>
      <a class="text-link" href={withBase("achievements/")}>
        查看全部成果
        <ArrowRight size={16} aria-hidden="true" />
      </a>
    </div>
  </section>
</BaseLayout>
